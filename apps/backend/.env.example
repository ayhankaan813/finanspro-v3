# FinansPro V3 Backend — Environment Variables
# Copy to .env and fill in your values

# ── Database ──
DATABASE_URL="postgresql://user:password@localhost:5432/finanspro_v3?schema=public"

# ── Server ──
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# ── JWT ──
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-change-in-production
JWT_ACCESS_EXPIRES_IN=4h
JWT_REFRESH_EXPIRES_IN=7d

# ── Logging ──
LOG_LEVEL=debug

# ── CORS (comma-separated for multiple origins) ──
CORS_ORIGIN=http://localhost:3000
